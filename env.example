# Get a key: https://open.pluralpolicy.com/accounts/profile/ (Open States / Plural)
OPENSTATES_API_KEY=

# Rate limits: each SEARCH_QUERIES phrase triggers its own search (plus pagination). If you see many
# "429" lines, use fewer phrases, set JURISDICTIONS, and/or slow requests down:
# OPENSTATES_MIN_INTERVAL_SEC=1.5   # minimum seconds between any two Open States GETs (default 1.0)
# OPENSTATES_PAGE_DELAY_SEC=3       # pause between search result pages (default 2.5)
# OPENSTATES_QUERY_GAP_SEC=8        # pause before each extra search phrase (default 6)
# OPENSTATES_MAX_RETRIES=18         # 429 retries per request (default 14)
# OPENSTATES_429_WAIT_CAP_SEC=600   # max seconds to honor Retry-After / backoff cap (default 600)
# OPENSTATES_ABORT_AFTER_429_COUNT=22  # exit with a clear message after this many 429s without success (default 22)

# Comma-separated full-text search phrases (each is a separate API search, results merged).
# Quote the value so `set -a && . ./.env && set +a` works (spaces break unquoted POSIX shell).
SEARCH_QUERIES='junk fee,junk fees,drip pricing,deceptive pricing'

# Bills are dropped unless their TITLE contains at least one of these phrases (case-insensitive).
# Open States full-text search can return unrelated bills; this is the gate for the dashboard.
# Comma-separated. Set BILL_TOPIC_TITLE_FILTER=0 to turn off and keep all search hits.
# BILL_TOPIC_KEYWORDS=junk fee,junk fees,junk-fee,junkfees,drip pricing,deceptive pricing,hidden fee,surprise fee,pricing transparency
# BILL_TOPIC_TITLE_FILTER=1

# Dashboard / data.json: set to 1 to list only bills with at least one dated milestone (intro, lower
# passage, upper passage, or signed/law). Drops rows where Open States has no matching classified actions yet.
# DASHBOARD_ONLY_WITH_MILESTONES=0

# Optional: limit to states, lowercase postal codes (comma-separated), e.g. ny,ca,mn
# JURISDICTIONS=

# Optional: always include specific bills (format jurisdiction:session:identifier per Open States URLs)
# Example: ny:2025:S363,ny:2025:A1821
# WATCH_BILLS=

# First run: set to 1 to record current state without sending alerts
# BOOTSTRAP_SILENT=1

# Optional Slack incoming webhook for alerts
# SLACK_WEBHOOK_URL=

# Optional: where to write data.json for the static dashboard (default: ./dashboard)
# DASHBOARD_DIR=

# End Junk Fees homepage snapshot (sync_endjunkfees_snapshot.py → campaign_snapshot.json in DASHBOARD_DIR)
# ENDJUNKFEES_URL=https://www.endjunkfees.com/

# --- GitHub Pages (no Open States secret in GitHub)
# Run tracker locally, commit dashboard/*.json, push. Workflow: .github/workflows/deploy-dashboard.yml
# Full steps: QUICKSTART.txt
# Vercel: QUICKSTART §6 — Root Directory = dashboard, Framework Other, empty build/output (no dist/).
# Tracker is stdlib-only (no requirements.txt at repo root; avoids Vercel’s Python preset).
#
# One-time snapshot (no database): python export_state_snapshot.py → exports/state_snapshot.json + .csv
